{
  "_COMMENT": "Copy this to settings.local.json and fill in APP_ID / INSTALL_ID after creating the macf-devops-agent GitHub App. The real settings.local.json is gitignored.",
  "env": {
    "APP_ID": "REPLACE_WITH_APP_ID",
    "INSTALL_ID": "REPLACE_WITH_INSTALLATION_ID",
    "KEY_PATH": ".github-app-key.pem",
    "MACF_AGENT_NAME": "macf-devops-agent",
    "MACF_WORKSPACE_DIR": "/home/ubuntu/repos/groundnuty/macf-devops-toolkit",
    "GIT_AUTHOR_NAME": "macf-devops-agent[bot]",
    "GIT_AUTHOR_EMAIL": "REPLACE_WITH_BOT_USER_ID+macf-devops-agent[bot]@users.noreply.github.com",
    "GIT_COMMITTER_NAME": "macf-devops-agent[bot]",
    "GIT_COMMITTER_EMAIL": "REPLACE_WITH_BOT_USER_ID+macf-devops-agent[bot]@users.noreply.github.com"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:cache.nixos.org)",
      "WebFetch(domain:releases.jetify.com)",
      "WebFetch(domain:charts.bitnami.com)",
      "WebFetch(domain:grafana.github.io)",
      "WebFetch(domain:langfuse.github.io)",
      "WebFetch(domain:open-telemetry.github.io)",
      "WebFetch(domain:prometheus-community.github.io)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TMUX\" ]; then TOKEN=$(\"$CLAUDE_PROJECT_DIR/.claude/scripts/macf-gh-token.sh\" --app-id \"$APP_ID\" --install-id \"$INSTALL_ID\" --key \"$KEY_PATH\" 2>/dev/null) || exit 0; DEVOPS=$(GH_TOKEN=$TOKEN gh issue list --repo groundnuty/macf-devops-toolkit --label devops-agent --state open --json number,title --jq '[.[0:5] | .[] | \"macf-devops-toolkit#\\(.number): \\(.title)\"] | join(\"; \")' 2>/dev/null); SCIENCE=$(GH_TOKEN=$TOKEN gh issue list --repo groundnuty/macf-science-agent --label devops-agent --state open --json number,title --jq '[.[0:5] | .[] | \"macf-science-agent#\\(.number): \\(.title)\"] | join(\"; \")' 2>/dev/null); MACF=$(GH_TOKEN=$TOKEN gh issue list --repo groundnuty/macf --label devops-agent --state open --json number,title --jq '[.[0:5] | .[] | \"macf#\\(.number): \\(.title)\"] | join(\"; \")' 2>/dev/null); ALL=$(echo \"$DEVOPS $SCIENCE $MACF\" | sed 's/^ *//;s/ *$//'); if [ -n \"$ALL\" ]; then sleep 3 && \"$CLAUDE_PROJECT_DIR/.claude/scripts/tmux-send-to-claude.sh\" \"\" \"Pick up pending issues: $ALL\" & fi; fi",
            "async": true
          }
        ]
      }
    ]
  }
}
