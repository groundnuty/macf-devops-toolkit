# EXAMPLE — NOT APPLIED BY ARGOCD.
# Copy this file to secrets.yaml, fill in the generated values, kubectl apply
# once, then commit secrets.yaml to the repo via `kubeseal` (recommended) or
# keep it local + gitignored (spike-only).
#
# Generate the five password/secret values each to ~32 chars:
#
#   openssl rand -base64 32         # salt, nextauth (base64)
#   openssl rand -hex 32            # encryptionKey (hex, 64 chars = 256 bits)
#   openssl rand -base64 24         # per-service passwords
#
# Apply: kubectl apply -n langfuse -f secrets.yaml (after creating the ns via argocd).
# If the ns doesn't exist yet: kubectl create namespace langfuse first.
#
# Note: do NOT commit this file with real secrets to the public repo. The
# .gitignore already excludes common secret patterns; this specific file is
# an EXAMPLE template meant to stay with PLACEHOLDERS in git.

---
apiVersion: v1
kind: Secret
metadata:
  name: langfuse-secrets
  namespace: langfuse
type: Opaque
stringData:
  # openssl rand -base64 32
  salt: "REPLACE_ME_WITH_openssl_rand_base64_32"
  # openssl rand -hex 32   (must be 64 hex chars / 256 bits)
  encryptionKey: "REPLACE_ME_WITH_openssl_rand_hex_32"
  # openssl rand -base64 32
  nextauth: "REPLACE_ME_WITH_openssl_rand_base64_32"

---
apiVersion: v1
kind: Secret
metadata:
  name: langfuse-postgresql
  namespace: langfuse
type: Opaque
stringData:
  # openssl rand -base64 24
  password: "REPLACE_ME_WITH_pg_password"

---
apiVersion: v1
kind: Secret
metadata:
  name: langfuse-redis
  namespace: langfuse
type: Opaque
stringData:
  # openssl rand -base64 24
  password: "REPLACE_ME_WITH_redis_password"

---
apiVersion: v1
kind: Secret
metadata:
  name: langfuse-clickhouse
  namespace: langfuse
type: Opaque
stringData:
  # openssl rand -base64 24
  password: "REPLACE_ME_WITH_clickhouse_password"

---
apiVersion: v1
kind: Secret
metadata:
  name: langfuse-s3
  namespace: langfuse
type: Opaque
stringData:
  # MinIO auth: both root-user + root-password are required.
  root-user: "langfuse-minio"
  # openssl rand -base64 24
  root-password: "REPLACE_ME_WITH_minio_root_password"
